// finance-porto schema
// Mirrors Pluggy Data API entities (Item, Account, Transaction)
// plus user-side models (Category, SyncLog).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id                    String    @id
  connectorId           Int
  connectorName         String
  connectorImageUrl     String?
  connectorPrimaryColor String?
  status                String
  executionStatus       String?
  statusDetail          String?
  pluggyCreatedAt       DateTime?
  pluggyUpdatedAt       DateTime?
  lastUpdatedAt         DateTime?
  consentExpiresAt      DateTime?

  accounts Account[]
  syncLogs SyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                   String  @id
  itemId               String
  item                 Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type                 String
  subtype              String
  name                 String
  marketingName        String?
  number               String?
  balance              Float
  currencyCode         String  @default("BRL")
  owner                String?
  taxNumber            String?
  creditLimit          Float?
  availableCreditLimit Float?
  // Current open credit-card bill (CREDIT accounts only). Source: pluggy.fetchCreditCardBills
  currentBillAmount    Float?
  currentBillDueDate   DateTime?
  currentBillMinimum   Float?
  // Manual override for the open bill — used when Pluggy can't reliably tell us
  // which installment lands in which future bill (Mercado Pago in particular
  // returns no `paymentData.installmentReferenceDate`). When set, the dashboard
  // and queries treat this as ground truth and skip the auto-computation.
  manualOpenBill        Float?
  manualOpenBillDueDate DateTime?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
}

model Transaction {
  id                      String   @id
  accountId               String
  account                 Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type                    String
  description             String
  descriptionRaw          String?
  amount                  Float
  amountInAccountCurrency Float?
  currencyCode            String   @default("BRL")
  date                    DateTime
  balance                 Float?
  pluggyCategory          String?
  pluggyCategoryId        String?
  merchantName            String?
  paymentDataJson         String?
  providerCode            String?

  userCategoryId String?
  userCategory   Category? @relation(fields: [userCategoryId], references: [id])
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId, date])
  @@index([date])
  @@index([userCategoryId])
}

model Category {
  id           String  @id @default(cuid())
  name         String  @unique
  emoji        String?
  color        String?
  monthlyLimit Float?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Long-term memory for the AI coach. Workspace-scoped (shared between Felipe
// and Milena, including across browser + WhatsApp). The coach reads these on
// every turn so it remembers preferences, goals and facts across conversations.
model CoachNote {
  id        String   @id @default(cuid())
  // Free-form bucket: "preference", "goal", "fact", "limit", "context", etc.
  category  String?
  content   String
  // Optional reference to who said it ("felipe" / "milena") — null = anyone.
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt(sort: Desc)])
}

model Conversation {
  id            String         @id @default(cuid())
  title         String         @default("Nova conversa")
  // When this conversation is bound to a WhatsApp phone (Evolution API),
  // every WA message from that phone lands here. Null for browser chats.
  whatsappPhone String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      CoachMessage[]

  @@index([updatedAt])
}

model CoachMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String
  // JSON-encoded list of tool calls used to produce this message:
  // [{ name: string, durationMs: number, ok: boolean }, ...]
  toolCallsJson  String?
  // OpenAI usage for this turn
  promptTokens   Int?
  completionTokens Int?
  cachedPromptTokens Int?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// Manual monthly budget — mirrors the structure of Milena's spreadsheet
// (`fatura_compras_MI.xlsx`). Two complementary models:
//   - FixedExpense: recurring monthly bills (aluguel, escola, mei, etc.)
//   - IncomeSource: recurring monthly income (salário, autônomo, pensão)
// Workspace-scoped (shared between Felipe + Milena).
//
// We keep these separate from Pluggy `Account` / `Transaction` because they
// are *plans*, not observations. Reconciliation is a separate concern: we
// match a paid date or `paid` toggle to incoming transactions later.
model FixedExpense {
  id        String  @id @default(cuid())
  // User-facing label ("Aluguel", "Convênio Helena", "Mei").
  name      String
  // Optional Pluggy category ID for cross-linking with auto-categorization.
  categoryId String?
  // Optional human category bucket — duplicates Milena's spreadsheet column
  // ("ALUGUEL", "CONVENIO", "ESCOLA"…). Free-form so she can re-create her
  // taxonomy without us locking it down.
  bucket    String?
  // Monthly amount in BRL.
  amount    Float
  // Day of the month the bill is due (1–31). Null when she just tracks it
  // monthly without a fixed due date.
  dueDay    Int?
  // Owner's first name (felipe / milena) — null = shared.
  owner     String?
  // Whether this is currently active. Soft-delete pattern so historical
  // months keep their reference.
  active    Boolean @default(true)
  // Optional notes ("varia ~50 a cada mês", "termina em 12/2026").
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, dueDay])
}

model IncomeSource {
  id        String  @id @default(cuid())
  name      String
  amount    Float
  // Expected day of receipt. Null when irregular.
  dueDay    Int?
  owner     String?
  active    Boolean @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model SyncLog {
  id                String    @id @default(cuid())
  itemId            String?
  item              Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  status            String
  itemsCount        Int       @default(0)
  accountsCount     Int       @default(0)
  transactionsCount Int       @default(0)
  errorMessage      String?

  @@index([startedAt])
}
