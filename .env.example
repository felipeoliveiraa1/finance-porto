# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
# Format: postgresql://USER:PASS@HOST:5432/postgres
# URL-encode special chars in the password (% → %25, etc.)
DATABASE_URL=""

# ─── Pluggy (Open Finance) ────────────────────────────────────────────────────
# Get at https://dashboard.pluggy.ai → Applications
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""
# Optional shared secret for /api/webhooks/pluggy
PLUGGY_WEBHOOK_SECRET=""

# ─── OpenAI (AI Coach) ────────────────────────────────────────────────────────
# Get at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Optional model override (default: gpt-4.1-mini)
# OPENAI_MODEL="gpt-4.1-mini"

# ─── Supabase Auth (REQUIRED em produção) ─────────────────────────────────────
# Pegue em: dashboard.supabase.com → seu projeto → Settings → API
# - URL é https://<project-ref>.supabase.co
# - Use a "anon public" key (não a service_role)
# Local dev: deixa vazio pra liberar tudo sem auth.
NEXT_PUBLIC_SUPABASE_URL="https://ffmztvgmchmvpbjenvcy.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Os usuários autorizados são cadastrados no painel do Supabase:
# Authentication → Users → "Add user" → email + senha
# (recomendado: desativar "Enable email signups" pra não permitir auto-cadastro)

# ─── WhatsApp via Evolution API ───────────────────────────────────────────────
# URL do Evolution API (self-hosted ou cloud)
EVOLUTION_API_URL="https://evo2.server.sermelhor.site"
# API key da instância (pode ser instance-key ou global)
EVOLUTION_API_KEY=""
# Nome da instância no Evolution (não é o UUID — é o "name" que aparece em /instance/fetchInstances)
EVOLUTION_INSTANCE="Finance"
# Secret opcional pro webhook (se setar aqui, configura também no Evolution dashboard
# em "Apikey" do webhook — qualquer string longa)
EVOLUTION_WEBHOOK_SECRET=""

# Números autorizados a conversar com a IA via WhatsApp (separados por vírgula, formato 5511...)
WHATSAPP_ALLOWED_PHONES="5511973304359,5511998002960"
# Números que recebem alertas + relatórios diários (default: mesmos do ALLOWED)
WHATSAPP_REPORT_PHONES="5511973304359,5511998002960"

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# Secret opcional (Vercel injeta automaticamente como Bearer token nas chamadas de cron)
CRON_SECRET=""
