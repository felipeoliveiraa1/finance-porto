# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
# Format: postgresql://USER:PASS@HOST:5432/postgres
# URL-encode special chars in the password (% → %25, etc.)
DATABASE_URL=""

# ─── Pluggy (Open Finance) ────────────────────────────────────────────────────
# Get at https://dashboard.pluggy.ai → Applications
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""
# Optional shared secret for /api/webhooks/pluggy
PLUGGY_WEBHOOK_SECRET=""

# ─── OpenAI (AI Coach) ────────────────────────────────────────────────────────
# Get at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Optional model override (default: gpt-4.1-mini)
# OPENAI_MODEL="gpt-4.1-mini"

# ─── Supabase Auth (REQUIRED em produção) ─────────────────────────────────────
# Pegue em: dashboard.supabase.com → seu projeto → Settings → API
# - URL é https://<project-ref>.supabase.co
# - Use a "anon public" key (não a service_role)
# Local dev: deixa vazio pra liberar tudo sem auth.
NEXT_PUBLIC_SUPABASE_URL="https://ffmztvgmchmvpbjenvcy.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Os usuários autorizados são cadastrados no painel do Supabase:
# Authentication → Users → "Add user" → email + senha
# (recomendado: desativar "Enable email signups" pra não permitir auto-cadastro)
